# Token Ledger Configuration Example

# Database Configuration
MONGO_URI=mongodb://localhost:27017/cryptocity
MONGO_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/cryptocity?retryWrites=true&w=majority

# Environment
NODE_ENV=development
# Options: development, testing, production

# Server Configuration
PORT=5000
API_BASE_URL=http://localhost:5000/api

# Token Configuration
TOKEN_NAME=LedgerToken
TOKEN_SYMBOL=LDG
TOKEN_DECIMALS=18

# Feature Flags
ENABLE_TOKEN_MINTING=true
ENABLE_TOKEN_TRANSFER=true
ENABLE_TOKEN_BURN=true
ENABLE_TOKEN_FREEZE=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
# minutes
RATE_LIMIT_MAX_REQUESTS=100
# requests per window

# Authentication (if needed)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug, trace

# Smart Contract Configuration (for future blockchain integration)
SMART_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
RPC_URL=http://localhost:8545
# For local development with Hardhat/Ganache
ETHERSCAN_API_KEY=your_etherscan_api_key

# API Configuration
API_VERSION=v1
API_TIMEOUT=30000
# milliseconds

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true

# Transaction Configuration
MAX_TRANSFER_AMOUNT=1000000000000000000000
# Max tokens per transaction (with decimals)
MIN_TRANSFER_AMOUNT=1000000000000000
# Min tokens per transaction (with decimals)

# Notification Configuration (optional)
ENABLE_NOTIFICATIONS=false
NOTIFICATION_SERVICE=email
# Options: email, webhook, socket

# Security
HELMET_ENABLED=true
REQUEST_SIGNATURE_VERIFICATION=false
# Enable signature verification for transactions

# Backup & Archive
ENABLE_BACKUP=true
BACKUP_INTERVAL=24
# hours
ARCHIVE_OLD_TRANSACTIONS=true
ARCHIVE_AFTER_DAYS=365
